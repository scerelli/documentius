{
  "app-id": "io.github.scerelli.Documentius",
  "runtime": "org.kde.Platform",
  "runtime-version": "6.9",
  "sdk": "org.kde.Sdk",
  "command": "documentius",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--filesystem=xdg-documents:rw",
    "--filesystem=xdg-download:ro",
    "--device=dri"
  ],
  "build-options": {
    "env": {
      "PYTHONPATH": "/app/lib/python3.12/site-packages"
    }
  },
  "modules": [
    {
      "name": "python3-pymupdf",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --no-index --find-links=. --prefix=/app PyMuPDF"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/ab/56/c6c16fa2dcfe2476ec28a9aaaca773dc35c593699e81e573211c91442770/pymupdf-1.27.2-cp310-abi3-manylinux_2_28_x86_64.whl",
          "sha256": "917f4dd52daea504d5c60e1430c17d637b5014a43e66d068b4b356effe087dba",
          "dest-filename": "pymupdf-1.27.2-cp310-abi3-manylinux_2_28_x86_64.whl"
        }
      ]
    },
    {
      "name": "python3-pyside6",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --no-index --find-links=. --prefix=/app shiboken6 PySide6_Essentials PySide6_Addons PySide6"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/52/88/292e0576489c46624ab419ee284ac5a59ae10e2eb34a58b6abca51dfd290/shiboken6-6.10.2-cp39-abi3-manylinux_2_34_x86_64.whl",
          "sha256": "ace0790032d9cb0adda644b94ee28d59410180d9773643bb6cf8438c361987ad",
          "dest-filename": "shiboken6-6.10.2-cp39-abi3-manylinux_2_34_x86_64.whl"
        },
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/99/20/3a6ca95052e1744b5a3eba164e2dd451d358a3dcaf78179de4b45c8e3f47/pyside6_essentials-6.10.2-cp39-abi3-manylinux_2_34_x86_64.whl",
          "sha256": "660aea45bfa36f1e06f799b934c2a7df963bd31abc5083e8bb8a5bfaef45686b",
          "dest-filename": "pyside6_essentials-6.10.2-cp39-abi3-manylinux_2_34_x86_64.whl"
        },
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/a5/69/e1ab8c756fd3984b1fd7b186446227f524f6b561160bfbfdba8874b4709a/pyside6_addons-6.10.2-cp39-abi3-manylinux_2_34_x86_64.whl",
          "sha256": "030a851163b51dbf0063be59e9ddb6a9e760bde89a28e461ccc81a224d286eaf",
          "dest-filename": "pyside6_addons-6.10.2-cp39-abi3-manylinux_2_34_x86_64.whl"
        },
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/35/d3/ab5cd2fac3d34469c7376e0cd18eec92905dbe44748c70bda7699a2a7206/pyside6-6.10.2-cp39-abi3-manylinux_2_34_x86_64.whl",
          "sha256": "1b89ce8558d4b4f35b85bff1db90d680912e4d3ce9e79ff804d6fef1d1a151ef",
          "dest-filename": "pyside6-6.10.2-cp39-abi3-manylinux_2_34_x86_64.whl"
        }
      ]
    },
    {
      "name": "python3-qtawesome",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --no-index --find-links=. --prefix=/app QtPy QtAwesome"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/69/76/37c0ccd5ab968a6a438f9c623aeecc84c202ab2fabc6a8fd927580c15b5a/QtPy-2.4.3-py3-none-any.whl",
          "sha256": "72095afe13673e017946cc258b8d5da43314197b741ed2890e563cf384b51aa1",
          "dest-filename": "QtPy-2.4.3-py3-none-any.whl"
        },
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/11/ef/b7c8c38d1717e2fcb777678ed11568b31062e34550e23297cc32e9e1105e/qtawesome-1.4.1-py3-none-any.whl",
          "sha256": "6a45f0ec214e0cd7c9c867772ec596799dcd5fae00a4b17717ff0d95d2e3fb64",
          "dest-filename": "qtawesome-1.4.1-py3-none-any.whl"
        }
      ]
    },
    {
      "name": "documentius",
      "buildsystem": "simple",
      "build-commands": [
        "cp -r documentius /app/lib/python3.12/site-packages/documentius",
        "install -Dm755 /dev/null /app/bin/documentius",
        "printf '#!/bin/sh\\nexec python3 -c \"from documentius.main import main; main()\"\\n' > /app/bin/documentius",
        "chmod 755 /app/bin/documentius",
        "install -Dm644 packaging/io.github.scerelli.Documentius.desktop /app/share/applications/io.github.scerelli.Documentius.desktop",
        "install -Dm644 packaging/io.github.scerelli.Documentius.metainfo.xml /app/share/metainfo/io.github.scerelli.Documentius.metainfo.xml",
        "install -Dm644 data/icons/documentius.svg /app/share/icons/hicolor/scalable/apps/io.github.scerelli.Documentius.svg",
        "install -Dm644 data/icons/io.github.scerelli.Documentius.256.png /app/share/icons/hicolor/256x256/apps/io.github.scerelli.Documentius.png",
        "install -Dm644 data/icons/io.github.scerelli.Documentius.128.png /app/share/icons/hicolor/128x128/apps/io.github.scerelli.Documentius.png",
        "install -Dm644 LICENSE /app/share/licenses/io.github.scerelli.Documentius/LICENSE"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/scerelli/documentius/releases/download/v0.0.0-local/documentius-0.0.0-local.tar.gz",
          "sha256": "COMPUTED_BY_CI",
          "strip-components": 1
        }
      ]
    }
  ]
}
